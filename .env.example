# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Bybit (for live trading — paper mode works without these) ─────────────────
# Bybit → User Center → API Management → Create Key
# Permissions: Read + Spot Trading ONLY. Never enable withdrawal.
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
