# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Bybit (for live trading — paper mode works without these) ─────────────────
# Bybit → User Center → API Management → Create Key
# Permissions: Read + Spot Trading ONLY. Never enable withdrawal.
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ── Dashboard Security ────────────────────────────────────────────────────────
# Set this to protect your dashboard with a password.
# When visiting the URL, browser will prompt for username + password.
# Username can be anything (e.g. "admin"), password must match this value.
# Leave blank/unset to disable password (not recommended on public Railway URL).
DASHBOARD_PASSWORD=your_strong_password_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
